        "\n",
        "import os\n",
        "import io\n",
        "import zipfile\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "from mp_api.client import MPRester\n",
        "from pymatgen.io.cif import CifWriter\n",
        "from google.colab import drive\n",
        "\n",
        
        "drive.mount('/content/drive')\n",
        "\n",
        
        "DRIVE_FOLDER = \"/content/drive/MyDrive/Perovskite_Dataset\"\n",
        "os.makedirs(DRIVE_FOLDER, exist_ok=True)\n",
        "\n",
        "API_KEY        = \"Input_API_KEY\"\n",
        "TARGET_SYSTEMS = [\"cubic\", \"monoclinic\", \"orthorhombic\", \"tetragonal\"]\n",
        "MAX_PER_CLASS  = 50000\n",
        "SAVE_PATH      = os.path.join(DRIVE_FOLDER, \"perovskite_cif.zip\")\n",
        "\n",
        "print(f\"File akan disimpan di: {SAVE_PATH}\")\n",
        "\n",
        
        "\n",
        "def load_and_save_cif_from_mp(api_key: str,\n",
        "                               target_systems: list,\n",
        "                               max_per_class: int = MAX_PER_CLASS,\n",
        "                               save_path: str = SAVE_PATH):\n",
        "    \"\"\"\n",
        "    Mengambil data perovskite dari Materials Project lalu menyimpan\n",
        "    setiap struktur kristal sebagai file .cif individual di dalam satu ZIP.\n",
        "\n",
        "    Penamaan file CIF:\n",
        "        {material_id}_{crystal_system}.cif\n",
        "        contoh: mp-2998_cubic.cif\n",
        "\n",
        "    Field yang diambil dari API:\n",
        "      - material_id   : identifier unik material (untuk nama file)\n",
        "      - formula_pretty: rumus kimia (untuk log)\n",
        "      - crystal_system: sistem kristal (untuk nama file & label)\n",
        "      - structure     : objek pymatgen Structure → dikonversi ke CIF\n",
        "    \"\"\"\n",
        "\n",
        "    data_records = []\n",
        "    class_counts = {c: 0 for c in target_systems}\n",
        "\n",
        "    with MPRester(api_key) as mpr:\n",
        "\n",
        
        "        print(\"Mencari material ID perovskite dari RoboCrystallographer...\")\n",
        "        robo_docs   = mpr.materials.robocrys.search(keywords=[\"perovskite\"])\n",
        "        perov_mpids = [str(doc.material_id) for doc in robo_docs][:50000]\n",
        "        print(f\"  → {len(perov_mpids)} material ID ditemukan\")\n",
        "\n",
        
        "        print(\"\\nMengambil summary material (field minimal)...\")\n",
        "        summaries = mpr.materials.summary.search(\n",
        "            material_ids=perov_mpids,\n",
        "            fields=[\n",
        "                \"material_id\",\n",
        "                \"formula_pretty\",\n",
        "                \"symmetry\",\n",
        "                \"structure\",\n",
        "            ],\n",
        "        )\n",
        "        print(f\"  → {len(summaries)} dokumen diterima\")\n",
        "\n",
        
        "        print(\"\\nMemfilter, mengkonversi ke CIF, dan menyimpan ke ZIP...\")\n",
        "        print(f\"  Lokasi ZIP: {save_path}\\n\")\n",
        "\n",
        "        with zipfile.ZipFile(save_path, \"w\", compression=zipfile.ZIP_DEFLATED) as zf:\n",
        "            for doc in summaries:\n",
        "\n",
        
        "                sym = getattr(doc, \"symmetry\", None)\n",
        "                if sym is None or sym.crystal_system is None:\n",
        "                    continue\n",
        "\n",
        "                cs_raw = sym.crystal_system\n",
        "                cs     = (cs_raw.value if hasattr(cs_raw, \"value\") else str(cs_raw).split(\".\")[-1]).lower()\n",
        "\n",
        "                if cs not in target_systems:\n",
        "                    continue\n",
        "                if class_counts[cs] >= max_per_class:\n",
        "                    continue\n",
        "                if doc.structure is None:\n",
        "                    continue\n",
        "\n",
        
        "                try:\n",
        "                    cif_string = str(CifWriter(doc.structure))\n",
        "                except Exception as e:\n",
        "                    print(f\"  ⚠ Gagal konversi CIF untuk {doc.material_id}: {e}\")\n",
        "                    continue\n",
        "\n",
        ,
        "                cif_filename = f\"{doc.material_id}_{cs}.cif\"\n",
        "\n",
        
        "                zf.writestr(cif_filename, cif_string)\n",
        "\n",
        
        "                data_records.append({\n",
        "                    \"material_id\"   : str(doc.material_id),\n",
        "                    \"formula\"       : str(doc.formula_pretty),\n",
        "                    \"crystal_system\": cs,\n",
        "                    \"cif_filename\"  : cif_filename,\n",
        "                })\n",
        "                class_counts[cs] += 1\n",
        "\n",
        
        "                total_so_far = sum(class_counts.values())\n",
        "                if total_so_far % 100 == 0:\n",
        "                    print(f\"  Progress: {total_so_far} material | {class_counts}\")\n",
        "\n",
        "                if all(class_counts[c] >= max_per_class for c in target_systems):\n",
        "                    print(\"\\n  → Semua kelas sudah mencapai batas MAX_PER_CLASS.\")\n",
        "                    break\n",
        "\n",
        
        "    df = pd.DataFrame(data_records)\n",
        "    csv_path = save_path.replace(\".zip\", \"_meta.csv\")\n",
        "    df.to_csv(csv_path, index=False)\n",
        "    print(f\"\\n  ✓ .zip tersimpan  → {save_path}\")\n",
        "    print(f\"  ✓ metadata .csv   → {csv_path}\")\n",
        "\n",
        "    return df\n",
        "\n",
        "\n",
        
        "\n",
        "print(\"=\" * 70)\n",
        "print(\"DOWNLOAD CIF PEROVSKITE DARI MATERIALS PROJECT\")\n",
        "print(\"=\" * 70)\n",
        "print(f\"Target crystal systems : {TARGET_SYSTEMS}\")\n",
        "print(f\"Max per class          : {MAX_PER_CLASS}\")\n",
        "print(f\"Simpan ke              : {DRIVE_FOLDER}\")\n",
        "print(\"=\" * 70 + \"\\n\")\n",
        "\n",
        "df_materials = load_and_save_cif_from_mp(\n",
        "    api_key        = API_KEY,\n",
        "    target_systems = TARGET_SYSTEMS,\n",
        "    max_per_class  = MAX_PER_CLASS,\n",
        "    save_path      = SAVE_PATH,\n",
        ")\n",
        "\n",
        
        "\n",
        "print(\"\\n\" + \"=\" * 70)\n",
        "print(\"RINGKASAN DATASET\")\n",
        "print(\"=\" * 70)\n",
        "print(f\"Total file CIF   : {len(df_materials)}\")\n",
        "print(f\"\\nDistribusi kelas:\")\n",
        "print(df_materials[\"crystal_system\"].value_counts().to_string())\n",
        "print(f\"\\nContoh metadata:\")\n",
        "print(df_materials.head(5).to_string(index=False))\n",
        "print(f\"\\nContoh nama file CIF di dalam ZIP:\")\n",
        "for name in df_materials[\"cif_filename\"].head(5):\n",
        "    print(f\"  → {name}\")\n",
        "\n",
        
        "\n",
              ],
